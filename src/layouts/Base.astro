---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  image?: string;
  current?: string;
  noFooter?: boolean;
}

const { title, description, image = 'https://images.unsplash.com/photo-1498050108023-c5249f4df085?w=1200&q=80', current = '', noFooter = false } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const fullTitle = title === 'Inicio' ? 'Valle Tech — Consultoría en tecnología para PyMEs' : `${title} — Valle Tech`;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <meta name="generator" content={Astro.generator} />

  <!-- SEO -->
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalURL} />
  <meta name="author" content="Antonio Valle — Valle Tech" />
  <meta name="robots" content="index, follow" />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={image} />
  <meta property="og:locale" content="es_MX" />
  <meta property="og:site_name" content="Valle Tech" />

  <!-- Twitter -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={fullTitle} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={image} />

  <!-- Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "ProfessionalService",
    "name": "Valle Tech",
    "description": "Consultoría en tecnología e inteligencia artificial para PyMEs en México",
    "url": "https://v4lle.tech",
    "address": { "@type": "PostalAddress", "addressLocality": "Tepic", "addressRegion": "Nayarit", "addressCountry": "MX" },
    "founder": { "@type": "Person", "name": "Antonio Valle" },
    "areaServed": "México"
  })} />

  <!-- Theme init (prevent flash) -->
  <script is:inline>
    (function(){
      var t = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', t);
    })();
  </script>

  <!-- Favicon -->
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

  <!-- No-JS fallback: show content that GSAP would normally reveal -->
  <noscript><style>.animate-fade-up,.animate-fade-in{opacity:1!important;transform:none!important}</style></noscript>
</head>
<body>
  <div class="cursor-blob" id="cursor-blob"></div>
  <div class="side-dots" id="side-dots"></div>
  <Nav current={current} />
  <main>
    <slot />
  </main>
  {!noFooter && <Footer />}

  <script>
    import { cursorBlob, sideDotsNav } from '../scripts/gsap-init';
    cursorBlob('#cursor-blob');
    sideDotsNav('#side-dots');
  </script>
</body>
</html>
