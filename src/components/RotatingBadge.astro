---
interface Props { size?: number; color?: string; }
const { size = 130, color = 'var(--accent)' } = Astro.props;
---
<div class="rotating-badge" style={`width:${size}px;height:${size}px`}>
  <svg viewBox="0 0 200 200" width={size} height={size} class="rotating-badge-svg">
    <defs><path id="badge-circle" d="M 100,100 m -72,0 a 72,72 0 1,1 144,0 a 72,72 0 1,1 -144,0" /></defs>
    <text style={`fill:${color};font-family:'Fira Code',monospace;font-size:11.5px;letter-spacing:3.5px;font-weight:500`}>
      <textPath href="#badge-circle">DISPONIBLE · TEPIC · 2026 · FREELANCE · DISPONIBLE · TEPIC · 2026 · </textPath>
    </text>
  </svg>
  <div class="rotating-badge-center">
    <svg width={size * 0.23} height={size * 0.23 * 0.75} viewBox="0 0 200 150" fill="none" aria-hidden="true">
      <g transform="translate(100,75)">
        <rect x="-65" y="-35" width="48" height="48" rx="1" transform="rotate(45)" fill={color} />
        <rect x="17" y="-35" width="48" height="48" rx="1" transform="rotate(45)" fill={color} />
        <rect x="17" y="13" width="48" height="48" rx="1" transform="rotate(45)" fill={color} />
      </g>
    </svg>
  </div>
</div>

<style>
  .rotating-badge{position:relative}
  .rotating-badge-svg{animation:spin-badge 16s linear infinite}
  .rotating-badge-center{position:absolute;top:50%;left:50%;transform:translate(-50%,-50%)}
</style>
