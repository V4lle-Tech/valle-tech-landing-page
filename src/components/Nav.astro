---
import VLogo from './VLogo.astro';

interface Props { current?: string; }
const { current = '' } = Astro.props;

const links = [
  { href: '/servicios', label: 'Servicios' },
  { href: '/portafolio', label: 'Portafolio' },
  { href: '/stack', label: 'Stack' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre-mi', label: 'Sobre mí' },
  { href: '/contacto', label: 'Contacto' },
];
---

<!-- Top nav -->
<nav class="nav" id="main-nav">
  <a href="/" class="nav-brand" aria-label="Inicio">
    <VLogo size={125} />
  </a>

  <div class="nav-actions">
    <button id="theme-toggle" class="nav-theme-btn" aria-label="Cambiar tema">
      <span class="theme-icon">☀️</span>
    </button>
    <a href="/contacto" class="nav-cta font-mono">Hablemos</a>
  </div>
</nav>

<!-- FAB -->
<button id="fab-menu" class="fab font-mono" aria-label="Abrir menú">
  <span class="fab-bars">
    <span class="fab-bar fab-bar-1"></span>
    <span class="fab-bar fab-bar-2"></span>
  </span>
  MENÚ
</button>

<!-- Fullscreen overlay menu -->
<div id="menu-overlay" class="menu-overlay closed" role="dialog" aria-modal="true" aria-label="Menú de navegación">
  <button id="menu-close" class="menu-close font-mono">✕ CERRAR</button>

  <div class="menu-theme-row">
    <button id="menu-theme-toggle" class="menu-theme-switch" aria-label="Cambiar tema">
      <span class="menu-theme-dot"></span>
    </button>
    <span class="font-mono menu-theme-label">DARK</span>
  </div>

  <nav class="menu-nav">
    {links.map((link, i) => (
      <a href={link.href}
        class:list={['menu-link font-display', { active: current === link.href }]}
        style={`--delay: ${i * 0.04}s`}
      >{link.label}</a>
    ))}
  </nav>

  <div class="menu-footer font-mono">hola@v4lle.tech · Tepic, Nayarit</div>
</div>

<style>
  .nav{
    position:fixed;top:0;left:0;right:0;z-index:150;
    display:flex;justify-content:space-between;align-items:center;
    padding:1rem 1.5rem;border-bottom:1px solid transparent;
    transition:all 0.4s,background 0.5s,border-color 0.5s;
  }
  .nav.scrolled{
    background:var(--nav-bg);backdrop-filter:blur(20px) saturate(1.2);
    border-bottom-color:var(--border);
  }
  .nav-brand{display:flex;align-items:center;gap:0.5rem;text-decoration:none;color:var(--text)}
  .nav-actions{display:flex;align-items:center;gap:0.8rem}
  .nav-theme-btn{
    background:none;border:1px solid var(--border);border-radius:8px;
    padding:0.35rem 0.6rem;font-size:0.7rem;transition:all 0.3s;cursor:pointer;
  }
  .nav-theme-btn:hover{border-color:var(--accent)}
  .nav-cta{
    background:var(--accent);color:#fff;border:none;padding:0.55rem 1.2rem;
    font-size:0.68rem;font-weight:500;letter-spacing:0.06em;text-transform:uppercase;
    border-radius:6px;transition:all 0.3s var(--ease);text-decoration:none;
  }
  .nav-cta:hover{filter:brightness(0.85)}

  .fab{
    position:fixed;bottom:1.5rem;right:1.5rem;z-index:200;
    display:flex;align-items:center;gap:0.6rem;
    padding:0.8rem 1.4rem;border-radius:50px;
    background:var(--fab-bg);color:var(--fab-text);border:none;
    font-size:0.7rem;font-weight:500;letter-spacing:0.08em;text-transform:uppercase;
    box-shadow:0 4px 24px var(--card-shadow);
    transition:all 0.4s var(--ease),background 0.5s,color 0.5s;
  }
  .fab:hover{transform:scale(1.06)}
  .fab.hidden{transform:scale(0);opacity:0;pointer-events:none}
  .fab-bars{display:flex;flex-direction:column;gap:3px}
  .fab-bar{display:block;height:1.5px;background:var(--fab-text);transition:background 0.5s}
  .fab-bar-1{width:16px}
  .fab-bar-2{width:10px;background:var(--accent)}

  .menu-overlay{
    position:fixed;inset:0;z-index:300;display:flex;flex-direction:column;
    align-items:center;justify-content:center;gap:0.3rem;
    background:var(--bg-menu);backdrop-filter:blur(30px);
    transition:opacity 0.5s var(--ease),visibility 0.5s;
  }
  .menu-overlay.closed{opacity:0;visibility:hidden;pointer-events:none}
  .menu-overlay.open{opacity:1;visibility:visible}

  .menu-close{
    position:absolute;top:1.5rem;right:1.5rem;
    background:none;border:none;color:var(--text-low);
    font-size:0.75rem;letter-spacing:0.1em;padding:0.5rem;transition:color 0.3s;
  }
  .menu-close:hover{color:var(--text-high)}

  .menu-theme-row{
    position:absolute;top:1.8rem;left:1.5rem;
    display:flex;align-items:center;gap:0.6rem;
  }
  .menu-theme-switch{
    width:44px;height:24px;border-radius:12px;border:none;
    background:var(--accent);cursor:pointer;position:relative;transition:background 0.4s;
  }
  .menu-theme-dot{
    position:absolute;top:2px;left:22px;width:20px;height:20px;border-radius:50%;
    background:#080808;transition:all 0.4s var(--ease);
    display:flex;align-items:center;justify-content:center;
  }
  .menu-theme-dot::after{content:'🌙';font-size:0.55rem}
  .menu-theme-label{font-size:0.6rem;color:var(--text-low);letter-spacing:0.06em}

  .menu-nav{display:flex;flex-direction:column;align-items:center;gap:0.05rem}
  .menu-link{
    font-weight:800;text-transform:uppercase;letter-spacing:-0.03em;
    padding:0.2rem 0;color:var(--text-low);font-size:clamp(1.8rem,6vw,4rem);
    transition:color 0.3s,transform 0.3s;
    opacity:0;transform:translateY(20px);
  }
  .menu-overlay.open .menu-link{
    opacity:1;transform:translateY(0);
    transition:color 0.3s,transform 0.5s var(--ease) var(--delay),opacity 0.4s var(--ease) var(--delay);
  }
  .menu-link:hover,.menu-link.active{color:var(--accent);transform:translateX(16px)}

  .menu-footer{position:absolute;bottom:2rem;font-size:0.6rem;color:var(--text-low);letter-spacing:0.08em}

  @media(min-width:768px){.nav{padding:1.2rem 3rem}}
</style>

<script>
  // Theme
  function getTheme() { return localStorage.getItem('theme') || 'dark'; }
  function setTheme(t: string) {
    document.documentElement.setAttribute('data-theme', t);
    localStorage.setItem('theme', t);
    const icon = document.querySelector('.theme-icon');
    if (icon) icon.textContent = t === 'dark' ? '☀️' : '🌙';
    const dot = document.querySelector('.menu-theme-dot') as HTMLElement;
    if (dot) { dot.style.left = t === 'dark' ? '22px' : '2px'; dot.style.background = t === 'dark' ? '#080808' : '#fff'; dot.setAttribute('data-after', t === 'dark' ? '🌙' : '☀️'); }
    const label = document.querySelector('.menu-theme-label');
    if (label) label.textContent = t === 'dark' ? 'DARK' : 'LIGHT';
    const sw = document.querySelector('.menu-theme-switch') as HTMLElement;
    if (sw) sw.style.background = t === 'dark' ? 'var(--accent)' : '#bbb';
  }
  setTheme(getTheme());

  document.getElementById('theme-toggle')?.addEventListener('click', () => setTheme(getTheme() === 'dark' ? 'light' : 'dark'));
  document.getElementById('menu-theme-toggle')?.addEventListener('click', () => setTheme(getTheme() === 'dark' ? 'light' : 'dark'));

  // Menu
  const overlay = document.getElementById('menu-overlay');
  const fab = document.getElementById('fab-menu');
  let previousFocus: HTMLElement | null = null;

  function openMenu() {
    previousFocus = document.activeElement as HTMLElement;
    overlay?.classList.replace('closed','open');
    fab?.classList.add('hidden');
    // Focus the close button for keyboard users
    const closeBtn = document.getElementById('menu-close');
    setTimeout(() => closeBtn?.focus(), 100);
  }

  function closeMenu() {
    overlay?.classList.replace('open','closed');
    fab?.classList.remove('hidden');
    // Restore focus to the element that opened the menu
    previousFocus?.focus();
  }

  document.getElementById('fab-menu')?.addEventListener('click', openMenu);
  document.getElementById('menu-close')?.addEventListener('click', closeMenu);
  overlay?.querySelectorAll('.menu-link').forEach(l => l.addEventListener('click', closeMenu));

  // Escape key closes menu
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && overlay?.classList.contains('open')) {
      closeMenu();
    }
  });

  // Focus trap inside menu overlay
  overlay?.addEventListener('keydown', (e) => {
    if (e.key !== 'Tab') return;
    const focusable = overlay.querySelectorAll<HTMLElement>('button, a[href], [tabindex]:not([tabindex="-1"])');
    if (!focusable.length) return;
    const first = focusable[0];
    const last = focusable[focusable.length - 1];
    if (e.shiftKey && document.activeElement === first) {
      e.preventDefault();
      last.focus();
    } else if (!e.shiftKey && document.activeElement === last) {
      e.preventDefault();
      first.focus();
    }
  });

  // Scroll
  window.addEventListener('scroll', () => {
    document.getElementById('main-nav')?.classList.toggle('scrolled', window.scrollY > 80);
  }, { passive: true });
</script>
