---
import portfolio from '../content/portfolio.json';

const cards = portfolio.map((p, i) => ({
  slug: p.slug,
  title: p.title,
  image: p.image,
  category: p.category,
  tags: p.tags.slice(0, 2),
  // Vary sizes for visual depth
  size: i === 0 ? 'lg' : i === 3 ? 'sm' : 'md',
}));
---

<div class="hero-orbital" id="hero-orbital">
  <div class="orbital-glow"></div>
  {cards.map((card, i) => (
    <a
      href={`/portafolio/${card.slug}`}
      class={`orbital-card orbital-card--${card.size}`}
      data-orbital-card
      data-orbital-index={i}
      style={`--i:${i}`}
    >
      <img src={card.image} alt={card.title} loading="eager" />
      <div class="orbital-card__overlay">
        <span class="orbital-card__cat font-mono">{card.category}</span>
        <span class="orbital-card__title font-display">{card.title}</span>
        <div class="orbital-card__tags">
          {card.tags.map(t => <span class="orbital-card__tag font-mono">{t}</span>)}
        </div>
      </div>
    </a>
  ))}
</div>

<style>
  .hero-orbital{
    position:relative;width:100%;height:100%;min-height:100vh;
    background:var(--bg);overflow:hidden;
  }

  .orbital-glow{
    position:absolute;top:50%;left:50%;transform:translate(-50%,-50%);
    width:40%;height:40%;border-radius:50%;
    background:radial-gradient(circle,var(--accent-glow) 0%,transparent 70%);
    pointer-events:none;
  }

  .orbital-card{
    position:absolute;border-radius:14px;overflow:hidden;
    cursor:pointer;text-decoration:none;color:#fff;
    border:1px solid rgba(255,255,255,0.08);
    box-shadow:0 8px 32px rgba(0,0,0,0.3);
    will-change:transform;
    opacity:0; /* GSAP will animate in */
    transition:box-shadow 0.4s var(--ease),border-color 0.4s var(--ease);
  }
  .orbital-card--lg{width:220px;height:160px}
  .orbital-card--md{width:180px;height:130px}
  .orbital-card--sm{width:150px;height:110px}

  .orbital-card img{
    width:100%;height:100%;object-fit:cover;
    transition:transform 0.6s var(--ease);
  }

  .orbital-card__overlay{
    position:absolute;inset:0;
    background:linear-gradient(to top,rgba(0,0,0,0.8) 0%,rgba(0,0,0,0.1) 60%,transparent 100%);
    display:flex;flex-direction:column;justify-content:flex-end;
    padding:0.8rem;opacity:0;
    transition:opacity 0.4s var(--ease);
  }

  .orbital-card__cat{
    font-size:0.5rem;letter-spacing:0.12em;text-transform:uppercase;
    color:var(--accent-bright);margin-bottom:0.2rem;
  }
  .orbital-card__title{
    font-size:0.72rem;font-weight:700;line-height:1.3;
    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
  }
  .orbital-card__tags{display:flex;gap:0.3rem;margin-top:0.3rem}
  .orbital-card__tag{
    font-size:0.45rem;letter-spacing:0.08em;text-transform:uppercase;
    padding:0.15rem 0.4rem;border-radius:10px;
    background:rgba(255,255,255,0.12);border:1px solid rgba(255,255,255,0.1);
  }

  /* Hover / focused state (class toggled by GSAP) */
  .orbital-card.is-focused{
    border-color:var(--accent);
    box-shadow:0 12px 48px rgba(43,127,255,0.25),0 0 0 1px var(--accent);
    z-index:10;
  }
  .orbital-card.is-focused img{transform:scale(1.08)}
  .orbital-card.is-focused .orbital-card__overlay{opacity:1}
</style>
