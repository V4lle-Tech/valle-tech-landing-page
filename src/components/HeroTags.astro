---
const tags = ['Python', 'React', 'IA', 'Cloud', 'Astro', 'DevOps', 'APIs', 'Automatización'];
const opacities = [0.9, 0.7, 1, 0.6, 0.8, 0.65, 0.75, 0.85];
---

<div class="hero-tags">
  {tags.map((tag, i) => (
    <span class="hero-tag font-mono" style={`opacity:${opacities[i]}`}>{tag}</span>
  ))}
</div>

<style>
  .hero-tags{
    position:absolute;inset:0;z-index:2;
    display:flex;flex-wrap:wrap;align-content:flex-end;
    gap:0.6rem;padding:3rem 2rem;
  }
  .hero-tag{
    font-size:0.6rem;letter-spacing:0.1em;text-transform:uppercase;
    color:#fff;padding:0.35rem 0.8rem;
    background:rgba(255,255,255,0.08);backdrop-filter:blur(4px);
    border:1px solid rgba(255,255,255,0.12);border-radius:20px;
    transition:all 0.3s var(--ease);
  }
  .hero-tag:hover{
    background:rgba(255,255,255,0.16);
    border-color:rgba(255,255,255,0.25);
    transform:translateY(-2px);
  }
</style>
