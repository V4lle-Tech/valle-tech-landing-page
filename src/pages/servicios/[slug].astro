---
import Base from '../../layouts/Base.astro';
import services from '../../content/services.json';

export function getStaticPaths() {
  return services.map(s => ({ params: { slug: s.slug }, props: { service: s } }));
}

const { service } = Astro.props;
const idx = services.findIndex(s => s.slug === service.slug);
const next = services[(idx + 1) % services.length];

const serviceSchema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "name": service.title,
  "description": service.description,
  "image": service.image,
  "provider": {
    "@type": "ProfessionalService",
    "name": "Valle Tech",
    "url": "https://v4lle.tech"
  },
  "areaServed": { "@type": "Country", "name": "México" },
  "url": `https://v4lle.tech/servicios/${service.slug}`
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://v4lle.tech/" },
    { "@type": "ListItem", "position": 2, "name": "Servicios", "item": "https://v4lle.tech/servicios" },
    { "@type": "ListItem", "position": 3, "name": service.title }
  ]
};
---

<Base title={service.title} description={service.description} image={service.image} current="/servicios" schema={[serviceSchema, breadcrumbSchema]}>

  <section class="page-hero" id="intro" data-nav-section="Intro">
    <div class="container">
      <a href="/servicios" class="back-link font-mono">← Todos los servicios</a>
      <p class="page-hero-label">0{idx + 1} — SERVICIO</p>
      <h1>{service.title}<span style="color:var(--accent)">.</span></h1>
    </div>
  </section>

  <section class="section-pad" id="detalle" data-nav-section="Detalle" style="padding-top:2rem">
    <div class="container">
      <div class="svc-grid">
        <div>
          <div class="img-block svc-hero-img" style="border-radius:10px;overflow:hidden;margin-bottom:2.5rem">
            <img src={service.image} alt={service.title} loading="eager" style="width:100%;height:100%;object-fit:cover" />
            <div class="overlay" style="background:rgba(1,85,187,0.15)"></div>
          </div>

          <p style="color:var(--text-mid);font-size:1.1rem;line-height:1.85;font-weight:300;margin-bottom:2rem">
            {service.description}
          </p>

          <h3 class="font-display" style="font-weight:800;font-size:1.2rem;text-transform:uppercase;letter-spacing:-0.02em;margin-bottom:1.2rem">
            Qué incluye<span style="color:var(--accent)">:</span>
          </h3>

          <div class="svc-details">
            {service.details.map((d, i) => (
              <div class="svc-detail-item">
                <span class="svc-detail-num font-mono">0{i + 1}</span>
                <p>{d}</p>
              </div>
            ))}
          </div>
        </div>

        <div class="svc-sidebar">
          <div class="card" style="margin-bottom:1.5rem">
            <h4 class="font-display" style="font-weight:700;font-size:0.95rem;text-transform:uppercase;margin-bottom:1rem">Tecnologías</h4>
            <div style="display:flex;gap:0.4rem;flex-wrap:wrap">
              {service.tags.map(tag => <span class="tag">{tag}</span>)}
            </div>
          </div>
          <div class="card">
            <h4 class="font-display" style="font-weight:700;font-size:0.95rem;text-transform:uppercase;margin-bottom:0.8rem">¿Te interesa?</h4>
            <p style="color:var(--text-mid);font-size:0.88rem;line-height:1.65;font-weight:300;margin-bottom:1.2rem">
              Platícame qué necesitas y te digo cómo puedo ayudarte. La primera consulta es gratis.
            </p>
            <a href="/contacto" class="btn-primary" style="width:100%;text-align:center;display:block">Agenda llamada →</a>
          </div>
        </div>
      </div>

      <!-- Next service -->
      <div style="border-top:1px solid var(--border);margin-top:4rem;padding-top:3rem;text-align:center">
        <span class="font-mono" style="font-size:0.6rem;color:var(--text-low);letter-spacing:0.15em">SIGUIENTE SERVICIO</span>
        <a href={`/servicios/${next.slug}`} class="next-svc font-display">{next.title} →</a>
      </div>
    </div>
  </section>

</Base>

<style>
  .back-link{font-size:0.65rem;color:var(--text-low);letter-spacing:0.08em;margin-bottom:1.5rem;display:inline-block;transition:color 0.3s}
  .back-link:hover{color:var(--accent)}
  .svc-grid{display:grid;grid-template-columns:1fr;gap:2rem}
  .svc-hero-img{height:300px}
  .svc-sidebar{position:sticky;top:6rem}
  @media(min-width:768px){.svc-grid{grid-template-columns:3fr 2fr;gap:3rem}.svc-hero-img{height:360px}}

  .svc-details{display:flex;flex-direction:column;gap:1rem;margin-bottom:2rem}
  .svc-detail-item{display:flex;gap:1rem;align-items:flex-start;padding:1rem 1.2rem;background:var(--bg-card);border:1px solid var(--border);border-radius:6px;transition:all 0.3s var(--ease)}
  .svc-detail-item:hover{border-color:var(--accent)}
  .svc-detail-num{font-size:0.55rem;color:var(--accent);letter-spacing:0.06em;min-width:20px;padding-top:0.15rem}
  .svc-detail-item p{color:var(--text-mid);font-size:0.9rem;line-height:1.6;font-weight:300;margin:0}

  .next-svc{display:block;font-weight:800;font-size:clamp(1.5rem,4vw,2.5rem);text-transform:uppercase;letter-spacing:-0.03em;margin-top:0.8rem;transition:color 0.3s}
  .next-svc:hover{color:var(--accent)}
</style>

<script>
  import { pageHeroReveal, revealBatch, revealElement } from '../../scripts/gsap-init';
  pageHeroReveal('.page-hero');
  revealElement('.svc-hero-img');
  revealBatch('.svc-detail-item');
  revealElement('.svc-sidebar');
</script>
