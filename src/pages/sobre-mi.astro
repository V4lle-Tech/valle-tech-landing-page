---
import Base from '../layouts/Base.astro';
import VLogo from '../components/VLogo.astro';
---

<Base title="Sobre mí" description="Antonio Valle — Consultor independiente en tecnología con más de 15 años de experiencia ayudando a PyMEs en México." current="/sobre-mi">

  <section class="page-hero" id="intro" data-nav-section="Intro">
    <div class="container">
      <p class="page-hero-label">SOBRE MÍ</p>
      <h1>No soy una<br/>agencia<span style="color:var(--accent)">.</span></h1>
      <p>
        Soy un consultor independiente que lleva más de 15 años
        resolviendo problemas con tecnología para PyMEs en México.
      </p>
    </div>
  </section>

  <section class="section-pad" id="historia" data-nav-section="Historia" style="padding-top:2rem">
    <div class="container">
      <div class="about-grid">
        <div>
          <h2 class="font-display section-title" style="margin-bottom:1.5rem">
            Cuando trabajas conmigo,<br/>trabajas conmigo<span style="color:var(--accent)">.</span>
          </h2>

          <div class="about-text">
            <p>
              Me llamo Antonio y vivo en Tepic, Nayarit. Empecé en esto hace más de 15 años
              — desde que montar un servidor web significaba pelear con Apache en una terminal.
              Desde entonces no he parado: he pasado por desarrollo web, bases de datos,
              servidores, apps móviles y ahora inteligencia artificial.
            </p>
            <p>
              Trabajo como freelance porque creo que así doy mejor servicio. Cuando me
              contratas, no te envió con otra persona — soy yo quien diseña la solución,
              escribe el código, configura el servidor y te contesta cuando algo falla
              un domingo a las 10 de la noche.
            </p>
            <p>
              Mi enfoque es simple: entender tu negocio primero, proponer después.
              No vendo tecnología por moda ni implemento cosas que no necesitas.
              Si lo que tienes funciona bien, te lo digo. Si necesita cambiar, te
              explico por qué y cuánto va a costar.
            </p>
            <p>
              Hoy uso inteligencia artificial en mi flujo de trabajo diario — me ayuda
              a programar más rápido, generar documentación y probar ideas. Eso se traduce
              en entregas más ágiles y precios más competitivos para ti. También la
              implemento en proyectos de clientes donde genera valor real: chatbots,
              lectura de documentos, análisis de datos.
            </p>
          </div>
        </div>

        <div>
          <div class="about-photo img-block" style="border-radius:10px;overflow:hidden;margin-bottom:2rem">
            <img src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=800&q=80" alt="Espacio de trabajo" loading="lazy" style="width:100%;height:100%;object-fit:cover" />
            <div class="overlay"></div>
            <div class="content about-photo-info">
              <p class="font-mono" style="font-size:0.6rem;color:rgba(255,255,255,0.5);letter-spacing:0.1em;text-transform:uppercase">Tepic, Nayarit · México</p>
              <p class="font-display" style="font-weight:800;font-size:1.3rem;color:#fff;text-transform:uppercase;letter-spacing:-0.02em;margin-top:0.3rem">Antonio Valle</p>
              <p style="font-size:0.82rem;color:rgba(255,255,255,0.6);font-weight:300">Consultor en tecnología · Freelance</p>
            </div>
          </div>

          <div class="about-values">
            <div class="card" style="margin-bottom:1rem">
              <h3 class="font-display" style="font-weight:700;font-size:0.95rem;display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem">
                <span style="width:14px;height:2px;background:var(--accent);display:inline-block;flex-shrink:0"></span>
                Trato directo
              </h3>
              <p style="color:var(--text-mid);font-size:0.86rem;line-height:1.6;font-weight:300;padding-left:1.4rem">
                Hablas conmigo, no con un intermediario. Conozco tu proyecto de cabo a rabo.
              </p>
            </div>
            <div class="card" style="margin-bottom:1rem">
              <h3 class="font-display" style="font-weight:700;font-size:0.95rem;display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem">
                <span style="width:14px;height:2px;background:var(--accent);display:inline-block;flex-shrink:0"></span>
                Precio cerrado
              </h3>
              <p style="color:var(--text-mid);font-size:0.86rem;line-height:1.6;font-weight:300;padding-left:1.4rem">
                Te digo cuánto va a costar desde el inicio. Sin sorpresas, sin extras escondidos.
              </p>
            </div>
            <div class="card">
              <h3 class="font-display" style="font-weight:700;font-size:0.95rem;display:flex;align-items:center;gap:0.5rem;margin-bottom:0.3rem">
                <span style="width:14px;height:2px;background:var(--accent);display:inline-block;flex-shrink:0"></span>
                Contexto mexicano
              </h3>
              <p style="color:var(--text-mid);font-size:0.86rem;line-height:1.6;font-weight:300;padding-left:1.4rem">
                SAT, facturación electrónica, regulaciones locales — no necesitas explicarme cómo funciona tu operación.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Timeline -->
  <section class="section-pad" id="trayectoria" data-nav-section="Trayectoria" style="border-top:1px solid var(--border)">
    <div class="container">
      <span class="section-label">TRAYECTORIA</span>
      <h2 class="section-title font-display" style="margin-bottom:3rem">15+ años<br/>en resumen<span style="color:var(--accent)">.</span></h2>

      <div class="bio-timeline">
        {[
          { year: '2009', text: 'Primeros proyectos web — PHP, MySQL, servidores compartidos. Todo era más difícil y eso me enseñó a no depender de herramientas mágicas.' },
          { year: '2013', text: 'Me especialicé en Laravel cuando salió la versión 4. Desde entonces es mi framework de cabecera para todo lo que construyo.' },
          { year: '2016', text: 'Empecé a trabajar con Vue.js y cambió mi forma de hacer interfaces. Combinado con Laravel, se volvió mi stack principal.' },
          { year: '2019', text: 'Migré mis primeros proyectos a la nube con Azure y Docker. Certificación en arquitectura de soluciones.' },
          { year: '2023', text: 'Incorporé inteligencia artificial en mi flujo de trabajo. Productividad por las nubes.' },
          { year: '2025', text: 'Lancé Valle Tech como marca de consultoría independiente. Hoy combino 15 años de experiencia con herramientas de IA.' },
        ].map(item => (
          <div class="bio-item">
            <span class="font-mono bio-year">{item.year}</span>
            <p>{item.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section-pad" id="contacto-cta" data-nav-section="Contacto" style="border-top:1px solid var(--border);text-align:center">
    <div class="container">
      <VLogo size={40} />
      <h2 class="font-display section-title" style="margin:1rem 0 1.5rem">¿Trabajamos juntos<span style="color:var(--accent)">?</span></h2>
      <p style="color:var(--text-mid);font-size:1.02rem;font-weight:300;max-width:440px;margin:0 auto 2.5rem;line-height:1.8">
        Si llegaste hasta aquí es porque algo te llamó la atención. Platiquemos.
      </p>
      <a href="/contacto" class="btn-primary">Agenda tu llamada →</a>
    </div>
  </section>

</Base>

<style>
  .about-grid{display:grid;grid-template-columns:1fr;gap:2.5rem}
  @media(min-width:768px){.about-grid{grid-template-columns:5fr 4fr;gap:3.5rem}}

  .about-text p{color:var(--text-mid);font-size:1.02rem;line-height:1.85;font-weight:300;margin-bottom:1.2rem}
  .about-photo{height:280px;position:relative}
  .about-photo img{width:100%;height:100%;object-fit:cover}
  .about-photo-info{position:absolute;bottom:0;left:0;right:0;padding:2rem}

  @media(min-width:768px){.about-photo{height:320px}}

  .bio-timeline{display:flex;flex-direction:column;gap:0}
  .bio-item{display:grid;grid-template-columns:60px 1fr;gap:1.5rem;padding:1.5rem 0;border-bottom:1px solid var(--border)}
  .bio-item:last-child{border-bottom:none}
  .bio-year{font-size:0.65rem;color:var(--accent);letter-spacing:0.08em;padding-top:0.15rem}
  .bio-item p{color:var(--text-mid);font-size:0.92rem;line-height:1.7;font-weight:300;margin:0}

  @media(min-width:768px){.bio-item{grid-template-columns:80px 1fr}}
</style>

<script>
  import { pageHeroReveal, revealBatch, revealElement } from '../scripts/gsap-init';
  pageHeroReveal('.page-hero');
  revealBatch('.about-text p');
  revealElement('.about-photo');
  revealBatch('.about-values .card');
  revealBatch('.bio-item');
</script>
