---
import Base from '../../layouts/Base.astro';
import posts from '../../content/posts.json';

export function getStaticPaths() {
  return posts.map(p => ({ params: { slug: p.slug }, props: { post: p } }));
}

const { post } = Astro.props;
const otherPosts = posts.filter(p => p.slug !== post.slug).slice(0, 2);

const blogSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  "headline": post.title,
  "description": post.excerpt,
  "image": post.image,
  "datePublished": post.date,
  "dateModified": post.date,
  "author": {
    "@type": "Person",
    "name": "Antonio Valle",
    "url": "https://v4lle.tech/sobre-mi"
  },
  "publisher": {
    "@type": "Organization",
    "name": "Valle Tech",
    "url": "https://v4lle.tech",
    "logo": { "@type": "ImageObject", "url": "https://v4lle.tech/favicon.svg" }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": `https://v4lle.tech/blog/${post.slug}`
  },
  "articleSection": post.category,
  "inLanguage": "es-MX"
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Inicio", "item": "https://v4lle.tech/" },
    { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://v4lle.tech/blog" },
    { "@type": "ListItem", "position": 3, "name": post.title }
  ]
};

const combinedSchema = [blogSchema, breadcrumbSchema];
---

<Base title={post.title} description={post.excerpt} image={post.image} current="/blog" schema={combinedSchema}>

  <article>
    <!-- Hero image -->
    <div class="post-hero img-block" id="portada" data-nav-section="Portada">
      <img src={post.image} alt={post.title} loading="eager" />
      <div class="overlay"></div>
    </div>

    <div class="section-pad" id="articulo" data-nav-section="Artículo" style="padding-top:3rem">
      <div class="prose">
        <a href="/blog" class="back-link font-mono">← Todos los artículos</a>

        <div class="post-meta">
          <span class="tag">{post.category}</span>
          <span class="font-mono" style="font-size:0.58rem;color:var(--text-low)">{post.readTime}</span>
          <time class="font-mono" style="font-size:0.58rem;color:var(--text-low)" datetime={post.date}>
            {new Date(post.date).toLocaleDateString('es-MX', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        </div>

        <h1 class="post-title font-display">{post.title}</h1>

        <div class="post-author">
          <div class="post-author-avatar font-display">AV</div>
          <div>
            <span style="font-weight:600;font-size:0.9rem">Antonio Valle</span>
            <span class="font-mono" style="display:block;font-size:0.6rem;color:var(--text-low)">Consultor en tecnología · Tepic, Nay.</span>
          </div>
        </div>

        <div set:html={post.content} />

        <!-- CTA -->
        <div class="post-cta card" style="margin-top:3rem;text-align:center">
          <h3 class="font-display" style="font-weight:800;font-size:1.2rem;text-transform:uppercase;margin-bottom:0.8rem">¿Quieres platicar sobre esto?</h3>
          <p style="color:var(--text-mid);font-size:0.9rem;font-weight:300;margin-bottom:1.5rem">Si algo de lo que leíste aplica para tu negocio, me encantaría escucharte.</p>
          <a href="/contacto" class="btn-primary" style="color:#fff;">Contáctame →</a>
        </div>
      </div>
    </div>
  </article>

  <!-- Related posts -->
  {otherPosts.length > 0 && (
    <section class="section-pad" id="relacionados" data-nav-section="Relacionados" style="border-top:1px solid var(--border)">
      <div class="container">
        <h3 class="section-label" style="margin-bottom:2rem">MÁS ARTÍCULOS</h3>
        <div class="related-grid">
          {otherPosts.map(p => (
            <a href={`/blog/${p.slug}`} class="blog-card-mini">
              <span class="tag" style="margin-bottom:0.5rem">{p.category}</span>
              <h4 class="font-display" style="font-weight:700;font-size:1rem;letter-spacing:-0.02em;line-height:1.3">{p.title}</h4>
              <span class="font-mono" style="font-size:0.58rem;color:var(--accent);margin-top:0.8rem;display:block">Leer →</span>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

</Base>

<style>
  .post-hero{height:clamp(250px,40vw,450px);position:relative;width:100%}
  .post-hero img{width:100%;height:100%;object-fit:cover}

  .back-link{font-size:0.65rem;color:var(--text-low);letter-spacing:0.08em;margin-bottom:2rem;display:inline-block;transition:color 0.3s;font-family:'Fira Code',monospace}
  .back-link:hover{color:var(--accent)}

  .post-meta{display:flex;align-items:center;gap:1rem;margin-bottom:1rem;flex-wrap:wrap}
  .post-title{font-weight:900;font-size:clamp(1.6rem,4vw,2.5rem);text-transform:uppercase;letter-spacing:-0.03em;line-height:1.1;margin-bottom:2rem}

  .post-author{display:flex;align-items:center;gap:1rem;margin-bottom:3rem;padding-bottom:2rem;border-bottom:1px solid var(--border)}
  .post-author-avatar{width:44px;height:44px;border-radius:50%;background:var(--accent);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:0.8rem}

  .related-grid{display:grid;grid-template-columns:1fr;gap:1.5rem}
  @media(min-width:768px){.related-grid{grid-template-columns:1fr 1fr;gap:2rem}}

  .blog-card-mini{
    display:block;padding:1.4rem 1.6rem;border:1px solid var(--border);border-radius:8px;
    transition:all 0.4s var(--ease);
  }
  .blog-card-mini:hover{border-color:var(--accent);transform:translateY(-3px);box-shadow:0 8px 20px var(--card-shadow)}
</style>

<script>
  import { revealBatch, revealElement } from '../../scripts/gsap-init';
  revealElement('.post-hero');
  revealBatch('.prose');
  revealElement('.post-author');
  revealBatch('.blog-card-mini');
</script>
